# ─── Server ───────────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/eventdb

# ─── Razorpay (leave blank until you have keys) ───────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Email (Gmail App Password) ───────────────────────────────
GMAIL_USER=your@gmail.com
GMAIL_APP_PASS=your_16_char_app_password

# ─── Admin ────────────────────────────────────────────────────
ADMIN_SECRET_TOKEN=replace_with_a_long_random_string

# ─── Event Details ────────────────────────────────────────────
EVENT_NAME=My Awesome Event
EVENT_DATE=December 31, 2025
EVENT_VENUE=City Convention Centre, Mumbai
EVENT_PRICE_GENERAL=500
EVENT_PRICE_VIP=1200
MAX_TICKETS_PER_ORDER=10

# ─── Support ──────────────────────────────────────────────────
SUPPORT_EMAIL=support@yourevent.com
